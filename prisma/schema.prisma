generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                  String   @id @default(cuid())
  name                String   @unique
  gender              String
  gender_probability  Float
  age                 Int
  age_group           String
  country_id          String
  country_name        String
  country_probability Float
  created_at          DateTime @default(now())
}
